# Root domain (no protocol). Tenant subdomains are <sub>.<ROOT_DOMAIN>.
# Local default is localhost:3000; set to your production domain on Vercel.
ROOT_DOMAIN=localhost:3000

# "Open tenant" link style. Unset/0 = path-based (/s/<sub>) — works everywhere.
# Set to 1 once a wildcard custom domain is in place to link to <sub>.<ROOT_DOMAIN>.
TENANT_SUBDOMAIN_LINKS=0

# --- Local tracing (infra/otel) — optional ---
# When set, @vercel/otel exports OTLP to the local collector. Leave unset to no-op.
# Bring the stack up first: docker compose -f infra/otel/docker-compose.yml up -d
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# --- Domain automation (scripts/add-domain.ts) — optional ---
# Never commit real values. Create .env.local (gitignored) for these.
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT=support-reliability-lab
